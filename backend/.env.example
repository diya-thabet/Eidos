# ??????????????????????????????????????????????????????????????
# Eidos — Environment Configuration
# Copy this file to .env and fill in the values.
# All variables are prefixed with EIDOS_ in the actual env.
# ??????????????????????????????????????????????????????????????

# ?? Database (any SQLAlchemy async URL) ??????????????????????
# PostgreSQL (default):
EIDOS_DATABASE_URL=postgresql+asyncpg://eidos:eidos@localhost:5432/eidos
# MySQL:      mysql+aiomysql://eidos:eidos@localhost:3306/eidos
# SQLite:     sqlite+aiosqlite:///./eidos.db

# Pool tuning (ignored for SQLite)
EIDOS_DB_POOL_SIZE=5
EIDOS_DB_MAX_OVERFLOW=10
EIDOS_DB_ECHO=false

# ?? Redis ????????????????????????????????????????????????????
EIDOS_REDIS_URL=redis://localhost:6379/0

# ?? Vector DB (Qdrant) ???????????????????????????????????????
EIDOS_QDRANT_URL=http://localhost:6333

# ?? LLM Provider (any OpenAI-compatible endpoint) ????????????
# Leave empty to use stub/mock responses (no real LLM calls)
EIDOS_OPENAI_API_KEY=
EIDOS_LLM_BASE_URL=
EIDOS_LLM_API_KEY=
EIDOS_LLM_MODEL=gpt-4o-mini
EIDOS_LLM_TEMPERATURE=0.1
EIDOS_LLM_MAX_TOKENS=2048
EIDOS_LLM_TIMEOUT=60

# ?? Authentication ???????????????????????????????????????????
# Set to true to enforce JWT auth on all endpoints
EIDOS_AUTH_ENABLED=false
EIDOS_SECRET_KEY=change-me-in-production-32-chars!
EIDOS_JWT_EXPIRE_SECONDS=86400

# GitHub OAuth (optional — needed for "Login with GitHub")
EIDOS_GITHUB_CLIENT_ID=
EIDOS_GITHUB_CLIENT_SECRET=
EIDOS_GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

# Google OAuth (optional — needed for "Login with Google")
EIDOS_GOOGLE_CLIENT_ID=
EIDOS_GOOGLE_CLIENT_SECRET=
EIDOS_GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ?? Repo Cloning ?????????????????????????????????????????????
EIDOS_REPOS_DATA_DIR=/data/repos
EIDOS_DELETE_CLONES_AFTER_INDEXING=true
